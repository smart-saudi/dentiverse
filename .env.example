# ============================================================
# DentiVerse — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it's in .gitignore.
# ============================================================

# ----------------------------------------------------------
# Supabase
# Get from: https://supabase.com/dashboard → Project → Settings → API
# For local dev: these are printed when you run `npx supabase start`
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------------------
# Stripe
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys for development (pk_test_ / sk_test_)
# ----------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ----------------------------------------------------------
# Resend (Email)
# Get from: https://resend.com/api-keys
# ----------------------------------------------------------
RESEND_API_KEY=re_your-api-key-here

# ----------------------------------------------------------
# Sentry (Error Tracking)
# Get from: https://sentry.io → Project → Settings → Client Keys
# ----------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=sntrys_your-auth-token-here

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DentiVerse

# ----------------------------------------------------------
# Optional Upload Transport
# Used only if you host a Tus endpoint for resumable uploads.
# Leave blank to use the default XHR upload route.
# ----------------------------------------------------------
NEXT_PUBLIC_UPPY_TUS_ENDPOINT=
